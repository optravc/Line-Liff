{
  "functions": {
    "backend/cmd/api/main.go": {
      "runtime": "vercel-go"
    }
  },
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend"
    }
  },
  "rewrites": [
    {
      "source": "/api/backend/(.*)",
      "destination": "/api/backend/cmd/api/main.go"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}