{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "functions": {
        "cmd/api/main.go": {
          "runtime": "vercel-go"
        }
      }
    }
  },
  "rewrites": [
    {
      "source": "/api/backend/(.*)",
      "destination": "/api/backend/cmd/api/main.go"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}