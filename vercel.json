{
  "services": {
    "frontend": {
      "root": "frontend",
      "framework": "nextjs"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "cmd/api/main.go"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/backend/cmd/api/main.go"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}