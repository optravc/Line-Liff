{
  "builds": [
    {
      "src": "backend/cmd/api/main.go",
      "use": "@vercel/go"
    },
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    }
  ],
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/cmd/api/main.go"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/$1"
    }
  ]
}